# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is listed in .gitignore.

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Auth / Admin ───────────────────────────────────────────────────────────────
ADMIN_TOKEN=
ADMIN_PASSWORD=

# ── OpenAI (server-side only — never prefix with VITE_ or NEXT_PUBLIC_) ────────
OPENAI_API_KEY=

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── App URL (used for invite emails and Stripe redirect URLs) ──────────────────
APP_URL=https://your-app.vercel.app

# ── Email (SendGrid or similar) ────────────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=

# ── Session ────────────────────────────────────────────────────────────────────
SESSION_SECRET=
JWT_SECRET=
