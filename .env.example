# ─────────────────────────────────────────────
# Elevate Performance Academy — Environment Variables
# Copy this file to .env and fill in your values.
# Set all of these as Secrets in Replit (Tools → Secrets).
# ─────────────────────────────────────────────

# Database — Neon PostgreSQL connection string
# Get this from your Neon project dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT secret — use a long random string in production (min 32 chars)
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars

# Admin bootstrap — used on first startup to create the admin account
ADMIN_PASSWORD=change_me_to_a_strong_password
ADMIN_TOKEN=change_me_to_a_long_random_token_min_64_chars

# App URL — public URL of the deployed app (used in invite email links)
APP_URL=https://elevate-performance-academy.replit.app

# Environment
NODE_ENV=production

# Resend email — required for invitation emails
# Get API key from resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must use your verified Resend domain
RESEND_FROM_EMAIL="Elevate Performance Academy <noreply@mail.elevateperformance-academy.com>"

# Stripe — required for billing/payment features
# Get keys from dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
VITE_STRIPE_PUBLIC_KEY=pk_live_...
